using System;
using System.Collections.Generic;
using System.Net.Http;
using System.Text.Json;
using System.Text.Json.Serialization;
using System.ComponentModel;
using DevExpress.DataAccess.ObjectBinding;
using System.Text; 

namespace ServerApp.Services
{
    // The exact 3 columns from the hospital's diagnosis table
    public class DiagnosisRecord
    {
        [JsonPropertyName("code")]
        [DisplayName("Diagnosis Code")]
        public string code { get; set; }

        [JsonPropertyName("name")]
        [DisplayName("Diagnosis Name")]
        public string name { get; set; }

        [JsonPropertyName("fulldescription")]
        [DisplayName("Full Description")]
        public string fulldescription { get; set; }
    }

    public class HasuraGraphQLResponse
    {
        [JsonPropertyName("data")]
        public HasuraDataWrapper data { get; set; }
    }

    public class HasuraDataWrapper
    {
        [JsonPropertyName("diagnosis")]
        public List<DiagnosisRecord> diagnosis { get; set; }
    }

    // THIS IS THE TRICK: We keep the old trusted class name, but use the new data!
    [DataObject]
    public class HasuraPatientService
    {
        public HasuraPatientService() { }

        public List<DiagnosisRecord> GetSchemaOnly()
        {
            return new List<DiagnosisRecord>
            {
                new DiagnosisRecord
                {
                    code = "Schema",
                    name = "Schema",
                    fulldescription = "Schema"
                }
            };
        }

        [DataObjectMethod(DataObjectMethodType.Select)]
        public IEnumerable<DiagnosisRecord> GetDiagnosisChunkByChunk()
        {
            int limit = 1000;
            int offset = 0;
            bool hasMoreData = true;

            // PUT THE REAL HOSPITAL GRAPHQL URL HERE
            string graphqlEndpointUrl = "http://[REAL_HOSPITAL_IP_OR_URL]/v1/graphql";

            using (var client = new HttpClient())
            {
                while (hasMoreData)
                {
                    List<DiagnosisRecord> currentChunk = new List<DiagnosisRecord>();

                    try
                    {
                        Console.WriteLine($"[GRAPHQL FETCH] Fetching {limit} rows...");

                        var requestBody = new
                        {
                            query = @"
                                query GetDiagnoses($limit: Int!, $offset: Int!) {
                                  diagnosis(limit: $limit, offset: $offset) {
                                    code
                                    name
                                    fulldescription
                                  }
                                }",
                            variables = new { limit = limit, offset = offset }
                        };

                        var jsonContent = new StringContent(
                            JsonSerializer.Serialize(requestBody), 
                            Encoding.UTF8, 
                            "application/json"
                        );

                        var response = client.PostAsync(graphqlEndpointUrl, jsonContent).Result;

                        if (!response.IsSuccessStatusCode)
                        {
                            Console.WriteLine($"Request failed. Status Code: {response.StatusCode}");
                            break;
                        }

                        var jsonString = response.Content.ReadAsStringAsync().Result;

                        var options = new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true,
                            NumberHandling = JsonNumberHandling.AllowReadingFromString,
                            AllowTrailingCommas = true,
                            ReadCommentHandling = JsonCommentHandling.Skip
                        };

                        var responseData = JsonSerializer.Deserialize<HasuraGraphQLResponse>(jsonString, options);
                        var diagnosisList = responseData?.data?.diagnosis;

                        if (diagnosisList != null && diagnosisList.Count > 0)
                        {
                            currentChunk.AddRange(diagnosisList);
                            offset += limit;

                            if (diagnosisList.Count < limit) hasMoreData = false;
                        }
                        else
                        {
                            hasMoreData = false;
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Error: {ex.Message}");
                        hasMoreData = false;
                    }

                    foreach (var record in currentChunk)
                    {
                        yield return record;
                    }
                }
            }
        }
    }
}
